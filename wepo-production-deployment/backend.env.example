MONGO_URL="mongodb://127.0.0.1:27018"
DB_NAME="wepo_staging"
WEPO_NODE_API_URL="http://127.0.0.1:8122"
WEPO_CANONICAL_APPLICATION_FEES_ENABLED="true"
WEPO_APP_FEE_SETTLEMENT_ADDRESS="wepo1replacewithfundedstagingaddress"
WEPO_ALLOWED_ORIGINS="https://staging.sparkpitlabs.com,https://sparkpitlabs.com"
# Behind the nginx proxy (which sets X-Real-IP $remote_addr) enable trusted
# forwarding so rate limiting keys on the true client IP, not the proxy.
WEPO_TRUST_PROXY_HEADERS="1"
