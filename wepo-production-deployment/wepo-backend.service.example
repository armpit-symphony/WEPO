[Unit]
Description=WEPO Canonical Backend API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=wepo
Group=wepo
WorkingDirectory=/opt/wepo/backend
EnvironmentFile=/etc/wepo/backend.env
Environment=PYTHONDONTWRITEBYTECODE=1
Environment=WEPO_REQUIRE_REDIS_RATE_LIMIT=1
ExecStart=/opt/wepo/.venv/bin/uvicorn server:app --host 127.0.0.1 --port 8011
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/wepo /var/log/wepo
LimitNOFILE=8192

[Install]
WantedBy=multi-user.target
