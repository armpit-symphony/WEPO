#
# Copy to frontend/.env for local development, or set REACT_APP_BACKEND_URL
# in your deployment environment before building the frontend.
#
# IMPORTANT (self-custody): point this at the server.py gateway (or the node API),
# which exposes /api/transaction/build-unsigned and accepts {signed_tx} on
# /api/transaction/send. The legacy wepo-fast-test-bridge.py is custodial and does
# NOT implement build-unsigned — do not use it for a self-custody build.
#
REACT_APP_BACKEND_URL=http://127.0.0.1:18021

# Private messaging feature flag. Must match the backend's WEPO_FEATURE_MESSAGING.
# Set to 1 to enable the in-wallet private messaging UI (launch-ready: key discovery
# is spend-key-bound/trustless). Leave empty/0 to hide messaging in the build.
REACT_APP_WEPO_FEATURE_MESSAGING=1

# Messaging relay endpoint (private messaging). Resolved separately from the
# wallet RPC backend so you can route messaging metadata over Tor: set this to a
# .onion hidden-service URL and access the wallet via Tor Browser (or a desktop
# build with a local SOCKS proxy). Leave empty to use REACT_APP_BACKEND_URL.
# NOTE: a browser cannot force Tor on its own — privacy here requires reaching
# this endpoint over Tor (Tor Browser / .onion / SOCKS proxy).
REACT_APP_MESSAGING_RELAY_URL=

# Block explorer. Leave empty to use the built-in in-wallet explorer (served by
# the gateway's privacy-aware /api/explorer/* endpoints). Set this to an external
# explorer URL to make the wallet's "Block Explorer" tile open that site in a new
# tab instead (useful once a standalone explorer is deployed).
REACT_APP_EXPLORER_URL=

WDS_SOCKET_PORT=443
