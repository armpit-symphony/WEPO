#
# Copy to backend/.env for local development or staging.
# Adjust values per environment before starting the backend.
#
MONGO_URL="mongodb://127.0.0.1:27018"
DB_NAME="wepo_test_wallet_lab"
WEPO_NODE_API_URL="http://127.0.0.1:18212"
WEPO_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100"
# Set to 1 ONLY when running behind a reverse proxy that overwrites X-Real-IP /
# X-Forwarded-For with the true client address (see nginx example). Leaving this
# unset makes rate limiting use the real socket peer so forwarding headers cannot
# be spoofed to bypass the limiter. Do not enable on a directly-exposed backend.
WEPO_TRUST_PROXY_HEADERS="0"
#
# Launch-scope feature flags (MAINNET_V1_LAUNCH_SCOPE.md). Disabled by default
# for v1; set to 1 only in staging or once a feature is launch-ready. Gated
# endpoints return HTTP 503 while disabled.
WEPO_FEATURE_PRIVACY="0"          # privacy proofs / Quantum Vault (zk-STARK)
WEPO_FEATURE_RWA="0"              # RWA assets, vault flows, and trading
WEPO_FEATURE_BTC="0"             # Bitcoin relay and atomic/BTC swaps
WEPO_ENABLE_STAGING_TOGGLES="0"  # staging-only test hooks (e.g. genesis flip)
